# Copy to e2e/.env.test (git-ignored) and fill in a real test account,
# or export these as environment variables in your shell / CI secrets.
# Nothing in this repo auto-loads this file — export the values yourself
# (e.g. `set -a; source e2e/.env.test; set +a`) before running `npm run test:e2e`.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
PLAYWRIGHT_BASE_URL=http://localhost:8081
